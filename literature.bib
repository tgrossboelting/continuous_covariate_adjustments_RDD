	pages = {187--199},
	file = {Full Text PDF:C\:\\Users\\tgrossbo\\Zotero\\storage\\2HDWYACD\\Crump et al. - 2009 - Dealing with limited overlap in estimation of aver.pdf:application/pdf;Snapshot:C\:\\Users\\tgrossbo\\Zotero\\storage\\R5SZQSLI\\235329.html:text/html},
