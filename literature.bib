@misc{imai_comment_2025,
	title = {Comment on "{Generic} machine learning inference on heterogeneous treatment effects in randomized experiments."},
	url = {http://arxiv.org/abs/2502.06758},
	doi = {10.48550/arXiv.2502.06758},
	abstract = {We analyze the split-sample robust inference (SSRI) methodology proposed by Chernozhukov, Demirer, Duflo, and Fernandez-Val (CDDF) for quantifying uncertainty in heterogeneous treatment effect estimation. While SSRI effectively accounts for randomness in data splitting, its computational cost can be prohibitive when combined with complex machine learning (ML) models. We present an alternative randomization inference (RI) approach that maintains SSRI's generality without requiring repeated data splitting. By leveraging cross-fitting and design-based inference, RI achieves valid confidence intervals while significantly reducing computational burden. We compare the two methods through simulation, demonstrating that RI retains statistical efficiency while being more practical for large-scale applications.},
	urldate = {2025-04-27},
	publisher = {arXiv},
	author = {Imai, Kosuke and Li, Michael Lingzhi},
	month = feb,
	year = {2025},
	note = {arXiv:2502.06758 [stat]},
	keywords = {Economics - Econometrics, Statistics - Methodology},
	file = {Preprint PDF:C\:\\Users\\tgrossbo\\Zotero\\storage\\5TNFW5YZ\\Imai and Li - 2025 - Comment on Generic machine learning inference on .pdf:application/pdf;Snapshot:C\:\\Users\\tgrossbo\\Zotero\\storage\\XSDP4LP3\\2502.html:text/html},
}

@article{caetano_robust_nodate,
	title = {Robust {Identiﬁcation} in {Regression} {Discontinuity} {Designs} with {Covariates}},
	abstract = {We study identiﬁcation, estimation and inference in the Regression Discontinuity Design (RDD) with covariates. We characterize the identiﬁcation of weighted averages of conditional local treatment eﬀects with interpretable weights (WLATEs). This family of estimands includes interesting parameters such as the standard RDD estimand without covariates, the average or equally weighted conditional treatment eﬀect, counterfactual averages, and the maximal average social welfare gain parameter. Within this general class, we consider the weights that maximize the “relevance” condition, and denote the corresponding estimand as the (Identiﬁcation-) Robust Local Average Treatment Eﬀect (RLATE). We propose estimators of the identiﬁable WLATEs, and establish their asymptotic normality. For a subclass that includes the RLATE, we also study the optimal bandwidth and develop bias-corrected inference. Monte Carlo simulations show that the RLATE estimator is more stable and generally has lower MSEs than the standard RDD and the RDD with covariates estimators. Finally, we implement our approach to identify the eﬀects of cash transfers during pregnancy on the incidence of low birthweight, as in Amarante et al. (2016), where we are able to conﬁrm their qualitative ﬁndings with an RDD identiﬁcation strategy.},
	language = {en},
	author = {Caetano, Carolina and Caetano, Gregorio and Escanciano, Juan Carlos},
	file = {Caetano et al. - Robust Identiﬁcation in Regression Discontinuity D.pdf:C\:\\Users\\tgrossbo\\Zotero\\storage\\L4R8MCV2\\Caetano et al. - Robust Identiﬁcation in Regression Discontinuity D.pdf:application/pdf},
}

