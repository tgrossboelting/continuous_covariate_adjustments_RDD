	keywords = {Heterogeneous treatment effects, machine learning, confidence intervals, GATES, randomization inference},
	pages = {1165--1170},
	file = {Full Text PDF:C\:\\Users\\tgrossbo\\Zotero\\storage\\9SYAUXU4\\Imai und Li - 2025 - A Comment on “Fisher–Schultz Lecture Generic Machine Learning Inference on Heterogeneous Treatment.pdf:application/pdf;Snapshot:C\:\\Users\\tgrossbo\\Zotero\\storage\\825LVS6W\\ECTA22261.html:text/html},
