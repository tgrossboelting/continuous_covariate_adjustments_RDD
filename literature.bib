@article{armstrong_simple_2020,
	title = {Simple and honest confidence intervals in nonparametric regression},
	volume = {11},
	copyright = {Copyright © 2020 The Authors.},
	issn = {1759-7331},
	url = {https://onlinelibrary.wiley.com/doi/abs/10.3982/QE1199},
	doi = {10.3982/QE1199},
	abstract = {We consider the problem of constructing honest confidence intervals (CIs) for a scalar parameter of interest, such as the regression discontinuity parameter, in nonparametric regression based on kernel or local polynomial estimators. To ensure that our CIs are honest, we use critical values that take into account the possible bias of the estimator upon which the CIs are based. We show that this approach leads to CIs that are more efficient than conventional CIs that achieve coverage by undersmoothing or subtracting an estimate of the bias. We give sharp efficiency bounds of using different kernels, and derive the optimal bandwidth for constructing honest CIs. We show that using the bandwidth that minimizes the maximum mean-squared error results in CIs that are nearly efficient and that in this case, the critical value depends only on the rate of convergence. For the common case in which the rate of convergence is n−2/5, the appropriate critical value for 95\% CIs is 2.18, rather than the usual 1.96 critical value. We illustrate our results in a Monte Carlo analysis and an empirical application.},
	language = {en},
	number = {1},
	urldate = {2025-01-29},
	journal = {Quantitative Economics},
	author = {Armstrong, Timothy B. and Kolesár, Michal},
	year = {2020},
	note = {\_eprint: https://onlinelibrary.wiley.com/doi/pdf/10.3982/QE1199},
	keywords = {C14, C21, Confidence intervals, nonparametric regression, regression discontinuity},
	pages = {1--39},
	file = {Full Text PDF:C\:\\Users\\tgrossbo\\Zotero\\storage\\SL9KLFG5\\Armstrong and Kolesár - 2020 - Simple and honest confidence intervals in nonparam.pdf:application/pdf;quan200073-sup-0001-onlineappendix.pdf:C\:\\Users\\tgrossbo\\Zotero\\storage\\YKYG6Z2R\\quan200073-sup-0001-onlineappendix.pdf:application/pdf;Snapshot:C\:\\Users\\tgrossbo\\Zotero\\storage\\XGWEGP23\\QE1199.html:text/html},
}

@misc{denteh_misclassification_2022,
	title = {Misclassification in {Difference}-in-differences {Models}},
	url = {http://arxiv.org/abs/2207.11890},
	doi = {10.48550/arXiv.2207.11890},
	abstract = {The difference-in-differences (DID) design is one of the most popular methods used in empirical economics research. However, there is almost no work examining what the DID method identifies in the presence of a misclassified treatment variable. This paper studies the identification of treatment effects in DID designs when the treatment is misclassified. Misclassification arises in various ways, including when the timing of a policy intervention is ambiguous or when researchers need to infer treatment from auxiliary data. We show that the DID estimand is biased and recovers a weighted average of the average treatment effects on the treated (ATT) in two subpopulations -- the correctly classified and misclassified groups. In some cases, the DID estimand may yield the wrong sign and is otherwise attenuated. We provide bounds on the ATT when the researcher has access to information on the extent of misclassification in the data. We demonstrate our theoretical results using simulations and provide two empirical applications to guide researchers in performing sensitivity analysis using our proposed methods.},
	urldate = {2025-01-25},
	publisher = {arXiv},
	author = {Denteh, Augustine and Kédagni, Désiré},
	month = jul,
	year = {2022},
	note = {arXiv:2207.11890 [econ]},
	keywords = {Economics - Econometrics, Statistics - Methodology},
