@article{gerard_partial_nodate,
	title = {Partial {Identiﬁcation} in {Regression} {Discontinuity} {Designs} with {Manipulated} {Running} {Variables}},
	abstract = {In a regression discontinuity design, units are assigned to receive a treatment if their value of a running variable lies above a known cutoﬀ. A key assumption to ensure point identiﬁcation of treatment eﬀects in this context is that units cannot manipulate the value of their running variable to guarantee or avoid assignment to the treatment. Standard identiﬁcation arguments break down if this condition is violated. This paper shows that treatment eﬀects remain partially identiﬁed even if some units are able to manipulate their running variable. We derive sharp bounds on the treatment eﬀects for the subpopulation of units that do not engage in manipulation, and show how to estimate them in practice. Our results apply to both sharp and fuzzy regression discontinuity designs. We use our method to study the eﬀect of unemployment insurance on unemployment duration in Brazil, where we ﬁnd strong evidence of manipulation at eligibility cutoﬀs.},
	language = {en},
	author = {Gerard, Francois and Rokkanen, Miikka and Rothe, Christoph},
	file = {Gerard et al. - Partial Identiﬁcation in Regression Discontinuity .pdf:C\:\\Users\\tgrossbo\\Zotero\\storage\\85I8YFWZ\\Gerard et al. - Partial Identiﬁcation in Regression Discontinuity .pdf:application/pdf},
}

@misc{lee_efficient_2023,
	title = {Efficient {Nonparametric} {Estimation} of {Stochastic} {Policy} {Effects} with {Clustered} {Interference}},
	url = {http://arxiv.org/abs/2212.10959},
	doi = {10.48550/arXiv.2212.10959},
	abstract = {Interference occurs when a unit's treatment (or exposure) affects another unit's outcome. In some settings, units may be grouped into clusters such that it is reasonable to assume that interference, if present, only occurs between individuals in the same cluster, i.e., there is clustered interference. Various causal estimands have been proposed to quantify treatment effects under clustered interference from observational data, but these estimands either entail treatment policies lacking real-world relevance or are based on parametric propensity score models. Here, we propose new causal estimands based on modification of the propensity score distribution which may be more relevant in many contexts and are not based on parametric models. Nonparametric sample splitting estimators of the new estimands are constructed, which allow for flexible data-adaptive estimation of nuisance functions and are consistent, asymptotically normal, and efficient, converging at the usual parametric rate. Simulations show the finite sample performance of the proposed estimators. The proposed methods are applied to evaluate the effect of water, sanitation, and hygiene facilities on diarrhea among children in Senegal.},
	urldate = {2023-10-11},
	publisher = {arXiv},
	author = {Lee, Chanhwa and Zeng, Donglin and Hudgens, Michael G.},
