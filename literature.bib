	keywords = {potential outcomes, unconfoundedness, average treatment effects, Matching estimators, selection on observables},
	pages = {235--267},
	file = {Full Text PDF:C\:\\Users\\tgrossbo\\Zotero\\storage\\MQTHIX8H\\Abadie and Imbens - 2006 - Large Sample Properties of Matching Estimators for.pdf:application/pdf},
