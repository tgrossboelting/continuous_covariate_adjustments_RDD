@article{cattaneo_causal_nodate-2,
	title = {Causal {Treatment} {Effect} {Aggregation} in {Boundary} {Discontinuity} {Designs}},
	abstract = {This paper analyzes two distinct approaches for estimating aggregated average treatment effects in boundary discontinuity designs: the widely-used pre-aggregation approach, and a novel post-aggregation approach. The pre-aggregation approach bundles all units near a treatment assignment boundary first, and then estimates a single, aggregated local average treatment effect. While commonly used in empirical work, its formal statistical properties remain underexplored. In contrast, the post-aggregation approach first estimates heterogeneous treatment effects along the assignment boundary, and then aggregates them, offering flexibility in weighting and robustness to boundary irregularities. We provide a precise definition of the aggregated causal parameters identified by each approach, and establish valid large-sample estimation and inference methods based on them. The theoretical results elucidate the relative merits of each aggregation approach, providing practical guidance for past and future applications of boundary discontinuity designs. General-purpose companion software is provided, and illustrated using an empirical application.},
	language = {en},
	author = {Cattaneo, Matias D and Titiunik, Rocio},
	file = {PDF:C\:\\Users\\tgrossbo\\Zotero\\storage\\T5LMU7LG\\Cattaneo und Titiunik - Causal Treatment Effect Aggregation in Boundary Discontinuity Designs.pdf:application/pdf},
}

@article{mbakop_model_2021,
	title = {Model {Selection} for {Treatment} {Choice}: {Penalized} {Welfare} {Maximization}},
	volume = {89},
	copyright = {© 2021 The Econometric Society},
	issn = {1468-0262},
	shorttitle = {Model {Selection} for {Treatment} {Choice}},
	url = {https://onlinelibrary.wiley.com/doi/abs/10.3982/ECTA16437},
	doi = {10.3982/ECTA16437},
	abstract = {This paper studies a penalized statistical decision rule for the treatment assignment problem. Consider the setting of a utilitarian policy maker who must use sample data to allocate a binary treatment to members of a population, based on their observable characteristics. We model this problem as a statistical decision problem where the policy maker must choose a subset of the covariate space to assign to treatment, out of a class of potential subsets. We focus on settings in which the policy maker may want to select amongst a collection of constrained subset classes: examples include choosing the number of covariates over which to perform best-subset selection, and model selection when approximating a complicated class via a sieve. We adapt and extend results from statistical learning to develop the Penalized Welfare Maximization (PWM) rule. We establish an oracle inequality for the regret of the PWM rule which shows that it is able to perform model selection over the collection of available classes. We then use this oracle inequality to derive relevant bounds on maximum regret for PWM. An important consequence of our results is that we are able to formalize model-selection using a “holdout” procedure, where the policy maker would first estimate various policies using half of the data, and then select the policy which performs the best when evaluated on the other half of the data.},
	language = {en},
	number = {2},
	urldate = {2026-01-19},
	journal = {Econometrica},
	author = {Mbakop, Eric and Tabord-Meehan, Max},
	year = {2021},
	note = {\_eprint: https://onlinelibrary.wiley.com/doi/pdf/10.3982/ECTA16437},
	keywords = {minimax-regret, statistical learning, Treatment choice},
	pages = {825--848},
	file = {Full Text PDF:C\:\\Users\\tgrossbo\\Zotero\\storage\\Z3JA3NT9\\Mbakop und Tabord-Meehan - 2021 - Model Selection for Treatment Choice Penalized Welfare Maximization.pdf:application/pdf;Snapshot:C\:\\Users\\tgrossbo\\Zotero\\storage\\9CSRJET3\\ECTA16437.html:text/html},
}

@misc{chen_efficient_2025,
	title = {Efficient {Difference}-in-{Differences} and {Event} {Study} {Estimators}},
	url = {http://arxiv.org/abs/2506.17729},
	doi = {10.48550/arXiv.2506.17729},
	abstract = {This paper investigates efficient Difference-in-Differences (DiD) and Event Study (ES) estimation using short panel data sets within the heterogeneous treatment effect framework, free from parametric functional form assumptions and allowing for variation in treatment timing. We provide an equivalent characterization of the DiD potential outcome model using sequential conditional moment restrictions on observables, which shows that the DiD identification assumptions typically imply nonparametric overidentification restrictions. We derive the semiparametric efficient influence function (EIF) in closed form for DiD and ES causal parameters under commonly imposed parallel trends assumptions. The EIF is automatically Neyman orthogonal and yields the smallest variance among all asymptotically normal, regular estimators of the DiD and ES parameters. Leveraging the EIF, we propose simple-to-compute efficient estimators. Our results highlight how to optimally explore different pre-treatment periods and comparison groups to obtain the tightest (asymptotic) confidence intervals, offering practical tools for improving inference in modern DiD and ES applications even in small samples. Calibrated simulations and an empirical application demonstrate substantial precision gains of our efficient estimators in finite samples.},
	urldate = {2026-01-21},
	publisher = {arXiv},
	author = {Chen, Xiaohong and Sant'Anna, Pedro H. C. and Xie, Haitian},
	month = jun,
	year = {2025},
	note = {arXiv:2506.17729 [econ]},
	keywords = {Economics - Econometrics, Mathematics - Statistics Theory},
	file = {Preprint PDF:C\:\\Users\\tgrossbo\\Zotero\\storage\\JF54WJWI\\Chen et al. - 2025 - Efficient Difference-in-Differences and Event Study Estimators.pdf:application/pdf;Snapshot:C\:\\Users\\tgrossbo\\Zotero\\storage\\YJLR7FB4\\2506.html:text/html},
}

@article{davezies_testing_nodate,
	title = {Testing {Heterogeneity} of {Average} {Treatment} {Effects} {Using} {Machine} {Learning} {Methods}},
	abstract = {We propose a formal test to check the heterogeneity of average treatment effects when these are estimated by machine learning methods. Our test statistic involves standard matrix computations and is easy to obtain. We propose a simple bootstrap procedure to obtain the critical values. Such a bootstrap procedure is fast, as it does not require computing the machine learning estimator at each bootstrap iteration.},
