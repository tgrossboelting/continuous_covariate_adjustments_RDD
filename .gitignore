# =========================
# Research project ignores
# =========================

# Data (never track raw data)
data/*
!data/.gitkeep

# Generated output
output/*
!output/.gitkeep

# LaTeX build files
*.aux
*.log
*.out
*.toc
*.lof
*.lot
*.fls
*.fdb_latexmk
*.synctex.gz
*.bbl
*.blg
*.bcf
*.run.xml
*.pdf

# Exceptions: non-rebuildable reference material (external papers,
# scanned notes, figures, etc.) lives under literature/ and must stay tracked.
!literature/literature_papers/**
!literature/literature_material/**

# Quarto / knitr builds
*_files/

# OS files
.DS_Store
Thumbs.db


# History files
.Rhistory
.Rapp.history

# Session Data files
.RData
.RDataTmp

# User-specific files
.Ruserdata

# Example code in package build process
*-Ex.R

# Output files from R CMD build
/*.tar.gz

# Output files from R CMD check
/*.Rcheck/

# RStudio files
.Rproj.user/

# produced vignettes
vignettes/*.html
vignettes/*.pdf

# OAuth2 token, see https://github.com/hadley/httr/releases/tag/v0.3
.httr-oauth

# knitr and R markdown default cache directories
*_cache/
/cache/

# Temporary files created by R markdown
*.utf8.md
*.knit.md

# R Environment Variables
.Renviron

# pkgdown site
docs/

# translation temp files
po/*~

# RStudio Connect folder
rsconnect/
